{
  "info": { "name": "Tesla E-Commerce API v1", "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json" },
  "item": [
    { "name": "Login", "request": { "method": "POST", "url": "http://localhost:3000/api/v1/auth/login",
      "header": [{ "key": "Content-Type", "value": "application/json" }],
      "body": { "mode": "raw", "raw": "{\"email\":\"customer@tesla.com\",\"password\":\"customer123\"}" } } },
    { "name": "List Products", "request": { "method": "GET", "url": "http://localhost:3000/api/v1/products?page=1&category=Vehicles" } },
    { "name": "Product Detail", "request": { "method": "GET", "url": "http://localhost:3000/api/v1/products/PRODUCT_ID" } },
    { "name": "Profile (JWT)", "request": { "method": "GET", "url": "http://localhost:3000/api/v1/user/profile",
      "header": [{ "key": "Authorization", "value": "Bearer YOUR_TOKEN" }] } },
    { "name": "Create Order (JWT)", "request": { "method": "POST", "url": "http://localhost:3000/api/v1/orders",
      "header": [{ "key": "Authorization", "value": "Bearer YOUR_TOKEN" }, { "key": "Content-Type", "value": "application/json" }],
      "body": { "mode": "raw", "raw": "{\"items\":[{\"product\":\"PRODUCT_ID\",\"quantity\":1}]}" } } }
  ]
}