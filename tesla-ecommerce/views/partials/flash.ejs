<% if (success && success.length) { %>
  <div class="flash flash-success"><%= success.join(' · ') %></div>
<% } %>
<% if (error && error.length) { %>
  <div class="flash flash-error"><%= error.join(' · ') %></div>
<% } %>
<% if (info && info.length) { %>
  <div class="flash flash-info"><%= info.join(' · ') %></div>
<% } %>