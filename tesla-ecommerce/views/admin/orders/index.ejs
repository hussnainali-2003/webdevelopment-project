<div class="page-head"><h1>Orders</h1></div>

<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th class="ps-3">Order ID</th><th>Customer</th><th>Total</th><th>Status</th><th>Date</th><th class="text-end pe-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!orders || orders.length === 0) { %>
          <tr><td colspan="6" class="text-center text-muted py-4">No orders yet.</td></tr>
        <% } else { %>
          <% orders.forEach(order => { %>
            <tr>
              <td class="ps-3"><code>#<%= order._id.toString().substring(0,8) %></code></td>
              <td><%= order.user ? order.user.name : '(deleted)' %></td>
              <td class="fw-medium">$<%= order.total.toFixed(2) %></td>
              <td><span class="badge-status badge-<%= order.status %>"><%= order.status %></span></td>
              <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
              <td class="text-end pe-3">
                <a href="/admin/orders/<%= order._id %>" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-eye"></i> Details</a>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
