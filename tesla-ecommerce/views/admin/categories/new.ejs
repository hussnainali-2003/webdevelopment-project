<div class="page-head"><h1>New Category</h1></div>
<form class="form-card" method="POST" action="/admin/categories">
  <div class="mb-3"><label class="form-label">Name</label><input class="form-control" name="name" required /></div>
  <div class="mb-3"><label class="form-label">Description</label><textarea class="form-control" name="description" rows="4"></textarea></div>
  <div class="d-flex gap-2">
    <button class="btn btn-primary" type="submit"><i class="fa-solid fa-plus me-1"></i> Create</button>
    <a href="/admin/categories" class="btn btn-light">Cancel</a>
  </div>
</form>
