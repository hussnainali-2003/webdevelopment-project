<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #f6f6f6; }
    
    .error-container {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      text-align: center;
    }
    
    .error-code {
      font-size: 120px;
      font-weight: 700;
      color: #e82127;
      margin-bottom: 20px;
    }
    
    .error-message {
      font-size: 24px;
      color: #1a1a1a;
      margin-bottom: 12px;
    }
    
    .error-description {
      font-size: 16px;
      color: #666;
      margin-bottom: 40px;
      max-width: 500px;
    }
    
    .btn {
      display: inline-block;
      padding: 12px 32px;
      background: #e82127;
      color: #fff;
      text-decoration: none;
      border-radius: 6px;
      font-weight: 600;
      transition: background 0.2s;
    }
    
    .btn:hover {
      background: #cc1a20;
    }
  </style>
</head>
<body>
  <div class="error-container">
    <div class="error-code">404</div>
    <div class="error-message">Page Not Found</div>
    <div class="error-description">The page you're looking for doesn't exist or has been moved.</div>
    <a href="/admin" class="btn">Back to Dashboard</a>
  </div>
</body>
</html>
