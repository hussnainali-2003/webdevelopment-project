<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/css/style.css" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #f6f6f6; }
    
    .admin-header {
      background: #000;
      color: #fff;
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 2px 8px rgba(0,0,0,.12);
    }
    
    .admin-header .brand {
      font-size: 20px;
      font-weight: 700;
      text-decoration: none;
      color: #fff;
      letter-spacing: 2px;
    }
    
    .admin-header nav {
      display: flex;
      gap: 24px;
      align-items: center;
    }
    
    .admin-header a {
      color: #fff;
      text-decoration: none;
      font-size: 14px;
      transition: opacity 0.2s;
    }
    
    .admin-header a:hover {
      opacity: 0.7;
    }
    
    .admin-header .cta {
      background: #e82127;
      padding: 8px 16px;
      border-radius: 6px;
      font-weight: 600;
    }
    
    .admin-main {
      max-width: 1200px;
      margin: 32px auto;
      padding: 0 16px;
    }
    
    .admin-main h1 {
      font-size: 28px;
      margin-bottom: 24px;
      color: #1a1a1a;
    }
    
    .success-msg {
      background: #e2f7e8;
      color: #1f7a36;
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 20px;
      font-size: 14px;
    }
    
    .admin-table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,.06);
    }
    
    .admin-table thead {
      background: #f0f0f0;
      border-bottom: 2px solid #e0e0e0;
    }
    
    .admin-table th {
      padding: 16px;
      text-align: left;
      font-weight: 600;
      font-size: 13px;
      color: #5c5e62;
      text-transform: uppercase;
    }
    
    .admin-table td {
      padding: 16px;
      border-bottom: 1px solid #e8e8e8;
      font-size: 14px;
    }
    
    .admin-table tbody tr:hover {
      background: #fafafa;
    }
    
    .thumb {
      width: 50px;
      height: 50px;
      object-fit: cover;
      border-radius: 6px;
    }
    
    .product-name {
      font-weight: 600;
      color: #1a1a1a;
    }
    
    .actions {
      display: flex;
      gap: 8px;
    }
    
    .btn {
      padding: 8px 16px;
      border: none;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      transition: all 0.2s;
    }
    
    .btn.primary {
      background: #e82127;
      color: #fff;
    }
    
    .btn.primary:hover {
      background: #cc1a20;
    }
    
    .btn.secondary {
      background: #f0f0f0;
      color: #1a1a1a;
    }
    
    .btn.secondary:hover {
      background: #e0e0e0;
    }
    
    .btn.danger {
      background: #fde8e8;
      color: #a02020;
    }
    
    .btn.danger:hover {
      background: #f9d4d4;
    }
    
    .btn.small {
      padding: 6px 12px;
      font-size: 12px;
    }
    
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: #888;
    }
    
    .empty-state svg {
      width: 64px;
      height: 64px;
      margin-bottom: 16px;
      opacity: 0.5;
    }
  </style>
</head>
<body>
  <header class="admin-header">
    <a href="/admin" class="brand">TESLA · Admin</a>
    <nav>
      <a href="/admin">Dashboard</a>
      <a href="/admin/new" class="cta">+ Add Product</a>
    </nav>
  </header>

  <main class="admin-main">
    <h1>Product Inventory (<%= products.length %>)</h1>

    <% if (message === 'created') { %>
      <div class="success-msg">✔ Product created successfully!</div>
    <% } else if (message === 'updated') { %>
      <div class="success-msg">✔ Product updated successfully!</div>
    <% } else if (message === 'deleted') { %>
      <div class="success-msg">✔ Product deleted successfully!</div>
    <% } %>

    <% if (products.length === 0) { %>
      <div class="empty-state">
        <p>No products yet. <a href="/admin/new">Create one now</a></p>
      </div>
    <% } else { %>
      <table class="admin-table">
        <thead>
          <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Category</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Rating</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach(function(p) { %>
            <tr>
              <td><img src="<%= p.image %>" alt="<%= p.name %>" class="thumb" /></td>
              <td><span class="product-name"><%= p.name %></span></td>
              <td><%= p.category %></td>
              <td><strong>$<%= p.price.toFixed(2) %></strong></td>
              <td><%= p.stock %></td>
              <td>★ <%= p.rating.toFixed(1) %></td>
              <td>
                <div class="actions">
                  <a href="/admin/<%= p._id %>/edit" class="btn secondary small">Edit</a>
                  <form action="/admin/<%= p._id %>?_method=DELETE" method="POST" style="display:inline">
                    <button type="submit" class="btn danger small" onclick="return confirm('Are you sure you want to delete <%= p.name %>?')">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </main>
</body>
</html>
