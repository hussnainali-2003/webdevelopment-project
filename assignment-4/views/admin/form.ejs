<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/css/style.css" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #f6f6f6; }
    
    .admin-header {
      background: #000;
      color: #fff;
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 2px 8px rgba(0,0,0,.12);
    }
    
    .admin-header .brand {
      font-size: 20px;
      font-weight: 700;
      text-decoration: none;
      color: #fff;
      letter-spacing: 2px;
    }
    
    .admin-header nav {
      display: flex;
      gap: 24px;
      align-items: center;
    }
    
    .admin-header a {
      color: #fff;
      text-decoration: none;
      font-size: 14px;
      transition: opacity 0.2s;
    }
    
    .admin-header a:hover {
      opacity: 0.7;
    }
    
    .admin-header .cta {
      background: #e82127;
      padding: 8px 16px;
      border-radius: 6px;
      font-weight: 600;
    }
    
    .admin-main {
      max-width: 600px;
      margin: 32px auto;
      padding: 0 16px;
    }
    
    .admin-main h1 {
      font-size: 28px;
      margin-bottom: 24px;
      color: #1a1a1a;
    }
    
    .error-msg {
      background: #fde8e8;
      color: #a02020;
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 20px;
      font-size: 14px;
    }
    
    .admin-form {
      background: #fff;
      padding: 32px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,.06);
    }
    
    .form-group {
      margin-bottom: 20px;
    }
    
    .form-group label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600;
      font-size: 14px;
      color: #1a1a1a;
    }
    
    .form-group small {
      color: #888;
      font-size: 12px;
    }
    
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 12px;
      border: 1px solid #d0d0d0;
      border-radius: 6px;
      font-size: 14px;
      font-family: inherit;
    }
    
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: #e82127;
      box-shadow: 0 0 0 2px rgba(232,33,39,.1);
    }
    
    .form-group textarea {
      resize: vertical;
      min-height: 100px;
    }
    
    .row-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    
    .image-preview {
      margin-top: 12px;
    }
    
    .image-preview img {
      max-width: 150px;
      max-height: 150px;
      border-radius: 6px;
      object-fit: cover;
    }
    
    .form-actions {
      display: flex;
      gap: 12px;
      margin-top: 32px;
    }
    
    .btn {
      padding: 12px 24px;
      border: none;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
      flex: 1;
    }
    
    .btn.primary {
      background: #e82127;
      color: #fff;
    }
    
    .btn.primary:hover {
      background: #cc1a20;
    }
    
    .btn.secondary {
      background: #f0f0f0;
      color: #1a1a1a;
    }
    
    .btn.secondary:hover {
      background: #e0e0e0;
    }
  </style>
</head>
<body>
  <header class="admin-header">
    <a href="/admin" class="brand">TESLA · Admin</a>
    <nav>
      <a href="/admin">Dashboard</a>
      <a href="/admin/new" class="cta">+ Add Product</a>
    </nav>
  </header>

  <main class="admin-main">
    <h1><%= product ? 'Edit Product' : 'Add New Product' %></h1>

    <% if (error) { %>
      <div class="error-msg">⚠️ <%= error %></div>
    <% } %>

    <form action="<%= formAction %>" method="<%= formMethod %>" enctype="multipart/form-data" class="admin-form">
      <div class="form-group">
        <label>Product Name *
          <input type="text" name="name" required value="<%= product ? product.name : '' %>" placeholder="e.g., Tesla Model Y" />
        </label>
      </div>

      <div class="form-group">
        <label>Category *
          <select name="category" required>
            <option value="">-- Select a category --</option>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat %>" <%= product && product.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </label>
      </div>

      <div class="row-grid">
        <div class="form-group">
          <label>Price ($) *
            <input type="number" name="price" step="0.01" min="0" required value="<%= product ? product.price : '' %>" placeholder="99.99" />
          </label>
        </div>

        <div class="form-group">
          <label>Stock Quantity
            <input type="number" name="stock" min="0" value="<%= product ? product.stock : 0 %>" placeholder="0" />
          </label>
        </div>
      </div>

      <div class="form-group">
        <label>Rating (0 - 5)
          <input type="number" name="rating" step="0.1" min="0" max="5" value="<%= product ? product.rating : 0 %>" placeholder="4.5" />
        </label>
      </div>

      <div class="form-group">
        <label>Description
          <textarea name="description" placeholder="Enter product description..."><%= product ? product.description : '' %></textarea>
        </label>
      </div>

      <div class="form-group">
        <label>Product Image <small>(jpg, png, webp, gif • max 5 MB)</small>
          <input type="file" name="image" accept="image/*" />
        </label>
        <% if (product && product.image) { %>
          <div class="image-preview">
            <p><strong>Current Image:</strong></p>
            <img src="<%= product.image %>" alt="<%= product.name %>" />
          </div>
        <% } %>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn primary">
          <%= product ? 'Update Product' : 'Create Product' %>
        </button>
        <a href="/admin" class="btn secondary">Cancel</a>
      </div>
    </form>
  </main>
</body>
</html>
