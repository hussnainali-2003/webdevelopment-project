<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/css/admin.css" />
</head>
<body>
  <header class="admin-header">
    <a href="/admin" class="brand">TESLA · Admin</a>
    <nav>
      <a href="/admin">Products</a>
      <a href="/admin/new" class="cta">+ Add Product</a>
      <a href="/products">View Shop ↗</a>
    </nav>
  </header>

  <main class="admin-main">
    <h1><%= product ? 'Edit Product' : 'Add Product' %></h1>

    <form action="<%= action %>" method="<%= method %>" enctype="multipart/form-data" class="admin-form">
      <label>Name
        <input type="text" name="name" required value="<%= product ? product.name : '' %>" />
      </label>

      <label>Category
        <select name="category" required>
          <% categories.forEach(function(c){ %>
            <option value="<%= c %>" <%= product && product.category === c ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </label>

      <div class="row">
        <label>Price ($)
          <input type="number" step="0.01" min="0" name="price" required value="<%= product ? product.price : '' %>" />
        </label>
        <label>Stock
          <input type="number" min="0" name="stock" value="<%= product ? product.stock : 0 %>" />
        </label>
        <label>Rating (0–5)
          <input type="number" step="0.1" min="0" max="5" name="rating" value="<%= product ? product.rating : 0 %>" />
        </label>
      </div>

      <label>Description
        <textarea name="description" rows="4"><%= product ? product.description : '' %></textarea>
      </label>

      <label>Image <small>(jpg/png/webp/gif, max 5 MB)</small>
        <input type="file" name="image" accept="image/*" />
        <% if (product && product.image) { %>
          <img src="<%= product.image %>" alt="current" class="thumb" style="margin-top:8px" />
        <% } %>
      </label>

      <div class="form-actions">
        <button type="submit" class="btn">Save</button>
        <a href="/admin" class="btn ghost">Cancel</a>
      </div>
    </form>
  </main>
</body>
</html>
